{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BG3 Save Manager",
  "version": "0.2.0",
  "identifier": "com.evernite.bg3savemanager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BG3 HonourMode Save Manager",
        "width": 1020,
        "height": 640,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["binaries/*"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEZEOTQwMEQxODdENDZGQUMKUldTc2I5U0gwUUNVL1NoMmlodk5zazYwT1VkZWVZLzhPTHlmeG9HQ3J1eFluL25lNXJhcFBUR1QK",
      "endpoints": [
        "https://github.com/Evernite-Dev/BG3-Save-Manager/releases/latest/download/latest.json"
      ]
    }
  }
}
